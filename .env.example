# =============================================================================
# Sparkmind — Environment Variables (contoh)
# =============================================================================
# Salin ke `apps/web/.env.local` untuk development. JANGAN commit file .env*.
# Aturan lengkap: .sparkmind/standards/environment.md
#
# Konvensi:
# - NEXT_PUBLIC_*  → boleh terekspos ke browser (nilai non-rahasia saja)
# - lainnya        → server-only (secret)
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Layanan pihak ketiga (diisi saat mulai dipakai, jangan sebelumnya) ---
# Supabase (Sprint 003+)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Clerk (saat auth dibutuhkan)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# AI provider via Vercel AI SDK (Sprint 003+)
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
